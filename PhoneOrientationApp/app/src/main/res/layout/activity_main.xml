<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:keepScreenOn="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/accelerometer_label"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvAccelX" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp"/>
    <TextView android:id="@+id/tvAccelY" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp"/>
    <TextView android:id="@+id/tvAccelZ" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp" android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gyroscope_label"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvGyroX" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp"/>
    <TextView android:id="@+id/tvGyroY" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp"/>
    <TextView android:id="@+id/tvGyroZ" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="16sp" android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/orientation_label"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvPitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp"/>
    <TextView android:id="@+id/tvRoll" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="20sp" android:textStyle="italic" android:textColor="#0066CC"/>

</LinearLayout>